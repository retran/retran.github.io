---
// Article layout — article page with title, date, topic tag, content slot
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  topic?: string;
}

const { title, description, date, topic } = Astro.props;
---

<Base title={`${title} — retran.me`} description={description}>
  <div class="post">
    <div class="post-info">
      {date && (
        <time datetime={date.toISOString().slice(0, 10)}>
          {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      {topic && <span class="post-topic">{topic}</span>}
    </div>

    <h1 class="post-title">{title}</h1>
    <div class="post-line"></div>

    <div class="prose">
      <slot />
    </div>
  </div>
</Base>
